# ═══════════════════════════════════════════════════════════════════
# MediCare AI Frontend — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# All Vite env vars must start with VITE_
# ═══════════════════════════════════════════════════════════════════

# ── API Connection ───────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_ENV=development

# ── Error Tracking ───────────────────────────────
VITE_SENTRY_DSN=

# ── Feature Flags ────────────────────────────────
VITE_FEATURE_FLAG_ENABLE_EXPERIMENTAL_SIMULATION=false
VITE_FEATURE_FLAG_ENABLE_ADVANCED_ANALYTICS=false
VITE_FEATURE_FLAG_ENABLE_NEW_DASHBOARD=false
VITE_FEATURE_FLAG_ENABLE_DEBUG_ROUTES=true
