# ═══════════════════════════════════════════════════════════════════
# MediCare AI Backend — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────
APP_ENV=development                           # development | staging | production
DEBUG=True                                     # Set to False in production
SECRET_KEY=change-this-in-production           # Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/medicare

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Authentication ───────────────────────────
JWT_SECRET_KEY=jwt-secret-change-in-production  # Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MIN=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (Gmail App Password) ───────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@medicare-ai.com

# ── Sentry Error Tracking ────────────────────────
SENTRY_DSN=

# ── LLM API Keys (fallback chain: Gemini → Groq → OpenRouter) ──
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Google Fit Integration ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_FIT_ENCRYPTION_KEY=
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── Feature Flags ────────────────────────────────
FEATURE_FLAG_ENABLE_EXPERIMENTAL_SIMULATION=false
FEATURE_FLAG_ENABLE_ADVANCED_ANALYTICS=false
FEATURE_FLAG_ENABLE_NEW_DASHBOARD=false
FEATURE_FLAG_ENABLE_DEBUG_ROUTES=true
